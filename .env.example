# Configurações de conexão com Bling API V3 e banco MySQL.
# Copie este arquivo para .env e preencha com seus dados reais.

# Bling Connection
BLING_API_URL=https://api.bling.com.br/Api/v3

BLING_CLIENT_ID=seu_client_id_aqui
BLING_CLIENT_SECRET=seu_client_secret_aqui

BLING_ACCESS_TOKEN=seu_access_token_aqui
BLING_REFRESH_TOKEN=seu_refresh_token_aqui

# MySQL Connection
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=sua_senha_aqui
MYSQL_DATABASE=bling_staging
